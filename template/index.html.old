<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Geckery</title>
    <link rel="icon" type="image/x-icon" href="images/favicon.ico">
    <style>
        body {
            margin: 0;
            background-color: rgb(87, 87, 87);
        }

        @import 'https://fonts.googleapis.com/css?family=Overlock:400,400i,700|Oleo+Script';

        .wrapper {
            height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
            perspective: 15px;
            position: relative;
        }

        header {
            position: relative;
            height: 100%;
            transform-style: preserve-3d;
            z-index: -1;
        }

        .background {
            transform: translateZ(-10px) scale(2);
            position: absolute;
            height: 400%;
            width: 100%;
            object-fit: cover;
            z-index: -1;
        }

    /* Title & Glow*/
    .title {
        /* text-shadow: 0 0 10px #fff, 0 0 1px #fff, 0 0 1px #fff, 0 0 1px #fff,0 0 1px #fff; */
        text-align: center;
        align-items: baseline;
        display: flex;
        justify-content: center;
        color: aliceblue;
        margin-top: 5%;
        font-family: STIX Two Text;
        font-weight: 600;
        line-height: 1.5;
    }
    
    .title div {
        margin: 0 15px;
    }

    .title a {
        padding: 30px;
        color: inherit;
        text-decoration: none;
    }

    /* Slogan */

    .slogan {
        color: aliceblue;
        text-align: center;
        align-items: baseline;
        display: flex;
        flex-direction: column;
        justify-content: center;
        margin-top: 15%;
        font-size: 40px;
        font-family: STIX Two Text;
        font-weight: 500;
        line-height: 1.5;
        width: 35%;
        max-width: fit-content;
        margin-left: auto;
        margin-right: auto;
        height: 300px;
    }

    .slogan .source {
        margin-left: auto;
        margin-right: auto;
        font-size: 20px; /* Adjust as needed for smaller font */
        margin-top: 5px; /* Adjust as needed for spacing */
        color: rgb(162, 167, 172)
    }



    .viewproducts {
        color: aliceblue;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 5% auto;
        font-size: 20px;
        background: #2290ac;
        width: 20%;
        height: 5%;
        padding: 10px 20px;
        border-radius: 100px;
        border: 1px solid transparent;
        transition: all .2s;
    }

    .viewproducts a {
        padding: 10px;
        color: inherit;
        text-decoration: none;
    }

    .container {
        display: flex;
        width: 100vw;
        height: 90%;
        padding: 20px;
        padding-bottom: 100px;
        background-color: #000;
    }

    .right-half {
        flex: 1;
        display: inline-block;
        justify-content: center;
        padding: 20px;
        color: #b6b6b6;
        padding-left: 50px; 
        background-color: #000;
    }

    .left-half {
        background-color: #000;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    model-viewer {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
    }
    
    * {box-sizing:border-box}

    /* Slideshow container */
    .slideshow-container {
    max-width: 1000px;
    position: relative;
    margin: auto;
    }

    /* Hide the images by default */
    .mySlides {
    display: none;
    }

    /* Position the "next button" to the right */
    .next {
    right: 0;
    border-radius: 3px 0 0 3px;
    }

    /* On hover, add a black background color with a little bit see-through */
    .prev:hover, .next:hover {
    background-color: rgba(0,0,0,0.8);
    }

    /* The dots/bullets/indicators */
    .dot {
    cursor: pointer;
    height: 15px;
    width: 15px;
    margin: 0 2px;
    background-color: #707070;
    border-radius: 50%;
    display: inline-block;
    transition: background-color 0.6s ease;
    }

    .active, .dot:hover {
    background-color: #bdbdbd;
    }

    /* Fading animation */
    .fade {
    animation-name: fade;
    animation-duration: 1.5s;
    }

    @keyframes fade {
    from {opacity: .1}
    to {opacity: 1}
    }

    .bottom-fade {
        width: 100%;
        bottom: 0;
        height: 50vh;
        z-index: 2;
        float: left;
        position: absolute;
        background: linear-gradient(to top, black 0%, rgba(0, 0, 0, 0.738) 19%, rgba(0, 0, 0, 0.541) 34%, rgba(0, 0, 0, 0.382) 47%, rgba(0, 0, 0, 0.278) 56.5%, rgba(0, 0, 0, 0.194) 65%, rgba(0, 0, 0, 0.126) 73%, rgba(0, 0, 0, 0.075) 80.2%, rgba(0, 0, 0, 0.042) 86.1%, rgba(0, 0, 0, 0.021) 91%, rgba(0, 0, 0, 0.008) 95.2%, rgba(0, 0, 0, 0.002) 98.2%, transparent 100%);
    }

    </style>


    <script>
    let slideIndex = 1;

    function plusSlides(n) {
        showSlides(slideIndex += n);
    }

    function currentSlide(n) {
        showSlides(slideIndex = n);
    }

    function showSlides(n) {
        console.log(n);
        let i;
        let slides = document.getElementsByClassName("mySlides");
        let dots = document.getElementsByClassName("dot");
        if (n > slides.length) { slideIndex = 1 }
        if (n < 1) { slideIndex = slides.length }
        for (i = 0; i < slides.length; i++) {
            slides[i].style.display = "none";
        }
        for (i = 0; i < dots.length; i++) {
            dots[i].className = dots[i].className.replace(" active", "");
        }
        slides[slideIndex - 1].style.display = "block";
        dots[slideIndex - 1].className += " active";
    }

    document.addEventListener('DOMContentLoaded', function() {
        showSlides(1);
    });

    setInterval(() => {
        slideIndex = (slideIndex % 3) + 1; // Cycle through 1, 2, 3
        showSlides(slideIndex);
        console.log(slideIndex)
    }, 10000);
    
    </script>

    <script>
        // HASH Changes script
        function scrollToHash() {
            // Get the current hash
            const hash = window.location.hash;

            // Define a mapping of hash values to elements
            const elementMap = {
                '#products': '.container',
                '#': '.title',
                '#aboutus': '#aboutus'
            };

            // Check if there's a hash in the URL
            if (hash in elementMap) {
                // Use the hash to find the element
                const selector = elementMap[hash];
                const element = document.querySelector(selector);

                // If the element exists, scroll to it
                if (element) {
                    element.scrollIntoView({ behavior: 'smooth' });
                }
            }
        }

        // Attach the scrollToHash function to the hashchange event
        window.addEventListener('hashchange', scrollToHash);

        // Call the function on page load in case there's an initial hash
        window.addEventListener('load', scrollToHash);
    </script>
</head>
<body>
    <div class="wrapper">
        <header>
            <img src="/images/background.jpg" class="background">
            <div class="title">
                <div style="font-size: 35px;">
                    <a href="#products">Products</a>
                </div>
                <div style="font-size: 70px; font-family: STIX Two Text;">
                    <a href="#">Geckery</a>
                </div>
                <div style="font-size: 35px;">
                    <a href="#aboutus">About Us</a>
                </div>
            </div>


            <div class="slideshow-container">
                <div class="mySlides fade">
                    <div class="slogan">
                        "The amazing quality on my workbench exceeds my expectations for any [PC] case."
                        <div class="source">
                            - IGN
                        </div>
                    </div>     
                </div>
              
                <div class="mySlides fade">
                    <div class="slogan">
                        "I really love these cases."
                        <div class="source">
                            - Ben
                        </div>
                    </div>     
                </div>
              
                <div class="mySlides fade">
                    <div class="slogan">
                        "Fortnite Battlepass"
                        <div class="source">
                            - Peter
                        </div>
                    </div>     
                </div>
              </div>
              <br>
              <br>
              <br>
              
              <!-- The dots/circles things -->
              <div style="text-align:center">
                <span class="dot" onclick="currentSlide(1)"></span>
                <span class="dot" onclick="currentSlide(2)"></span>
                <span class="dot" onclick="currentSlide(3)"></span>
              </div>
          
            <div class="viewproducts">
                <a href="#products">
                    View our Products
                </a>
            </div>
            <div class="bottom-fade"></div>
        </header>
        <div class="container">
            <div class="left-half">
                <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
                <model-viewer id="productModel" alt="PC Case Model" src="models/case1.glb" ar environment-image="models/blue.hdr" shadow-intensity="1" camera-controls="none" touch-action="pan-y" disable-zoom></model-viewer>
            </div>
            <div class="right-half">
                <h1 style="font-size: 50px;">Product</h1>
                <p style="font-size: 20px;">Introducing our premium laser-cut wooden PC case, crafted with precision for the modern enthusiast. This sleek and stylish case combines the warmth of natural wood with robust durability, offering superior airflow and easy assembly. Elevate your setup with a touch of elegance and unique craftsmanship. Perfect for those who value both performance and aesthetics.</p>
            </div>
        </div>
    </div>
</body>
</html>
